# Copy to .env and fill in your keys.  .env is gitignored.

# --- Census API key ---
# Free signup: https://api.census.gov/data/key_signup.html
# Without one, the Census API limits you to 500 requests/day per IP.
CENSUS_API_KEY=

# --- Google Cloud (Vertex AI for Gemini 2.5 Flash) ---
# The runtime uses Gemini 2.5 Flash on Vertex AI for extraction,
# synthesis, and a few mid-pipeline LLM calls.
#
# You need:
#   1. A GCP project with the Vertex AI API enabled.
#   2. Application-default credentials:
#         gcloud auth application-default login
#   3. Either set GCP_PROJECT_ID here, or pass it via gcloud config.
GCP_PROJECT_ID=

# --- HuggingFace token for data-layer hydration ---
# Free signup: https://huggingface.co/settings/tokens  (Read access is enough.)
# Only needed for the one-time hydrate step that downloads the
# pre-built gazetteer + FAISS index + peer feature DB.
HF_TOKEN=
